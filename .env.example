# LLM
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=15432
POSTGRES_HOST_PORT=15432
POSTGRES_DB=trip_planner
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# Redis
REDIS_HOST=localhost
REDIS_PORT=16379
REDIS_HOST_PORT=16379

# Backend AMap REST tools
AMAP_API_KEY=your-amap-rest-api-key
ENABLE_AMAP_MCP=false

# Frontend API and AMap JS SDK
NEXT_PUBLIC_API_URL=http://localhost:8000
API_INTERNAL_URL=http://localhost:8000
NEXT_PUBLIC_AMAP_KEY=your-amap-js-api-key
NEXT_PUBLIC_AMAP_SECRET=your-amap-js-security-code
NEXT_PUBLIC_USE_MOCK=false

# Development and demo options
DEMO_MODE=false
DEMO_FALLBACK_ENABLED=true
PRELOAD_EMBEDDING_MODEL=false
LLM_THINKING_ENABLED=false
INTENT_EXTRACTION_LLM_ENABLED=true
